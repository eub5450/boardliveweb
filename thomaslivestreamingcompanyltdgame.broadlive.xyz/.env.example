APP_NAME="Play BD Game"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=play
DB_USERNAME=play_user
DB_PASSWORD=change_me

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@your-domain.example
MAIL_FROM_NAME="${APP_NAME}"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_ENCRYPTED=true
PUSHER_TIMEOUT=10

BD_GAME_FINAL_ENTRY_TOKEN_TTL_SECONDS=90
BD_GAME_FINAL_SESSION_TTL_SECONDS=18000
BD_GAME_FINAL_CACHE_ENABLED=true
BD_GAME_FINAL_CACHE_STORE=file
BD_GAME_FINAL_CACHE_PREFIX=bdgf:v7:
BD_GAME_FINAL_CACHE_TTL_SECONDS=2
BD_GAME_FINAL_REALTIME_ENABLED=false
BD_GAME_FINAL_POLL_FALLBACK_MS=1500
BD_GAME_FINAL_PUSHER_FORCE_TLS=true
BD_GAME_FINAL_PUSHER_ENCRYPTED=true
BD_GAME_FINAL_PUSHER_TRANSPORTS=ws,wss
BD_GAME_FINAL_WEBSOCKET_ENABLED=true
BD_GAME_FINAL_WEBSOCKET_URL=ws://127.0.0.1:6001
BD_GAME_FINAL_WEBSOCKET_EVENT=bd.game.state
BD_GAME_FINAL_DISPATCH_VIA_QUEUE=false
 
# App-Based Access Control
# Package names are recorded for audit only; they are not trusted by themselves.
BD_GAME_FINAL_ALLOWED_APP_PACKAGES=

# Developer authentication requires a strong secret plus a configured real user.
# Prefer BD_GAME_FINAL_DEVELOPER_PASSWORD_HASH for production secret storage.
BD_GAME_FINAL_DEVELOPER_PASSWORD=
BD_GAME_FINAL_DEVELOPER_PASSWORD_HASH=
BD_GAME_FINAL_APP_ACCESS_USER_ID=

# Admin panel second-pass security. Use either a 24+ character secret or SHA-256 hash.
BD_GAME_FINAL_ADMIN_SECURITY_SECRET=
BD_GAME_FINAL_ADMIN_SECURITY_SECRET_HASH=
BD_GAME_FINAL_ADMIN_SECURITY_SESSION_TTL=1800
BD_GAME_FINAL_ADMIN_SECURITY_MAX_ATTEMPTS=5
BD_GAME_FINAL_ADMIN_SECURITY_LOCKOUT_SECONDS=900

BD_GAME_FINAL_QUEUE=default
BD_GAME_FINAL_WATCH_SLEEP_SECONDS=1
