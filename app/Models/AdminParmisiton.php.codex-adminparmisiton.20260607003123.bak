    public static function groupedDefinitions(): array
    {
        $groups = [];
        foreach (self::definitions() as $key => $definition) {
            $groups[$definition['group']][$key] = $definition['label'];
        }
        return $groups;
    }

    public static function allowed($userId, string $permissionKey, bool $default = false): bool
    {
        if (!$userId) {
            return false;
        }

        if (!Schema::hasTable('adminparmisiton')) {
            return $default;
        }

        $cacheKey = 'adminparmisiton:'.(int) $userId.':'.$permissionKey;
        return (bool) Cache::remember($cacheKey, 60, function () use ($userId, $permissionKey, $default) {
            $row = self::where('user_id', (int) $userId)
                ->where('permission_key', $permissionKey)
                ->first();

            return $row ? (bool) $row->is_allowed : $default;
        });
    }

    public static function syncUserPermissions(int $userId, array $enabledKeys, ?int $actorId = null): void
    {
        $enabled = array_flip($enabledKeys);
        foreach (self::definitions() as $key => $definition) {
            self::updateOrCreate(
                ['user_id' => $userId, 'permission_key' => $key],
                [
                    'permission_label' => $definition['label'],
                    'permission_group' => $definition['group'],
                    'is_allowed' => isset($enabled[$key]) ? 1 : 0,
                    'updated_by' => $actorId,
                    'created_by' => $actorId,
                ]
            );
            Cache::forget('adminparmisiton:'.$userId.':'.$key);
        }
    }

    public static function matrixForUsers($userIds): array
    {
        $ids = collect($userIds)->map(function ($id) {
            return (int) $id;
        })->filter()->unique()->values();

        if ($ids->isEmpty() || !Schema::hasTable('adminparmisiton')) {
            return [];
        }

        $matrix = [];
        self::whereIn('user_id', $ids)->get()->each(function ($row) use (&$matrix) {
            $matrix[(int) $row->user_id][$row->permission_key] = (int) $row->is_allowed === 1;
        });

        return $matrix;
    }
}
