    public function Info($id)
    {
        $user=User::find($id);
        $agency=Agency::orderby('id','desc')->first();
        $next_agency_code=$agency->code+1;
        return response()->json(['success' => 'User Find','user'=>$user,'next_agency_code'=>$next_agency_code]);
    }
