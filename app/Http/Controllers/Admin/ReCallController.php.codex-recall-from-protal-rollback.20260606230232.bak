<?php

namespace App\Http\Controllers\Admin;

use App\Http\Controllers\Controller;
use Illuminate\Http\Request;
use App\Models\User;
use Auth;
use App\Models\Gift;
use Illuminate\Support\Facades\DB;

class ReCallController extends Controller
{
    public function Create()
    {
        $data['users']=User::all();
        $data['protals']=User::where('is_coin_protal_active',1)->get();
        return view('backend.protal.recall_create')->with($data);
    }

    public function GetData($id)
    {
        $data=User::find($id);
        return response()->json(['success' => 'User Find','data'=>$data]);
    }

    public function RecallStore(Request $request)
    {
        $request->validate([
            'user_id' => 'required|integer',
            'protal_id' => 'required|integer',
            'amount' => 'required|numeric|min:1',
        ]);

        $user=User::find($request->user_id);
        $portal=User::where('id', $request->protal_id)->where('is_coin_protal_active',1)->first();
        $amount = (float) $request->amount;

        if (!$user || !$portal) {
            return Redirect()->back()->with([
                'messege'=>'User or protal data not found',
                'alert-type'=>'error'
            ]);
        }

        if ($user->balance < $amount) {
             return Redirect()->back()->with([
                'messege'=>'User Balance Not Avaliabel',
                'alert-type'=>'warning'
            ]);
        }

        try {
            DB::transaction(function () use ($user, $portal, $amount) {
                $user->balance -= $amount;
                $user->save();

                DB::table('recall_from_protal')->insert([
                    'protal_id' => $portal->id,
                    'source_user_id' => $user->id,
                    'amount' => -1 * abs($amount),
                    'date' => date('Y-m-d'),
                    'user_id' => Auth::id(),
                    'trxid' => 'recall-'.rand(2586,589898),
                    'remarks' => 'Recall balance from user to protal',
                    'created_at' => now(),
                    'updated_at' => now(),
                ]);
            });

            return Redirect()->back()->with([
                'messege'=>'Protal Recall SuccessFully!',
                'alert-type'=>'success'
            ]);
        } catch (\Throwable $error) {
            return Redirect()->back()->with([
                'messege'=>'Somnthing Wrong!!',
                'alert-type'=>'error'
            ]);
        }
    }

    public function Index()
    {
        $data=DB::table('recall_from_protal')->orderby('id','desc')->get();
        return view('backend.protal.recall_index',compact('data'));
    }

    public function GiftRecall($id)
    {
         $gift=Gift::find($id);
         if ($gift) {
             $user=User::find(555555);
             $user->balance+=$gift->value;
             if ($user->save()) {
                $gift->delete();
             }
             $notification=array(
                'messege'=>'Gift Recall SuccessFully',
                'alert-type'=>'success'
            );
            return Redirect()->back()->with($notification);
         }else{
             $notification=array(
                'messege'=>'Somnthing Wrong!!',
                'alert-type'=>'warning'
            );
            return Redirect()->back()->with($notification);
         }


    }
}
