    public function VipActived($id,$vip)
    {
       
      $user=User::find($id);
      $check_old_vip=VipList::where('user_id',$user->id)->where('vip_no',$vip)->first();
      if(!$check_old_vip){
          $data=new VipList;
          $data->vip_no=$vip;
          $data->user_id=$user->id;
          $data->active_date=Carbon\Carbon::now();
          $data->is_active=0;
          $data->end_date=Carbon\Carbon::now()->addDays(15);
          
          if($vip==1){
              $data->image='store/vip/1.png';
          }elseif($vip==2){
               $data->image='store/vip/2.png';
          }elseif($vip==3){
               $data->image='store/vip/3.png';
          }elseif($vip==4){
               $data->image='store/vip/4.png';
          }elseif($vip==5){
               $data->image='store/vip/5.png';
          }elseif($vip==6){
               $data->image='store/vip/6.png';
          }elseif($vip==7){
               $data->image='store/vip/7.png';
          }
          $data->save();
           $notification=array(
                'messege'=>'VIP Active Successfully',
                'alert-type'=>'success'
            );
            return Redirect()->back()->with($notification);
      }else{
          $notification=array(
                'messege'=>'This Vip Already Have In Store',
                'alert-type'=>'success'
            );
            return Redirect()->back()->with($notification);
      }
    }
