    public function EffectActive($user_id,$id){
        $check_old_effect=MyBeg::where('user_id',$user_id)->where('store_id',$id)->first();
        if(!$check_old_effect){
            $check_effect=EntryFrame::find($id);
            $data=new MyBeg;
            $data->store_id=$id;
            $data->user_id=$user_id;
            $data->status=0;
            $data->active_time=Carbon\Carbon::now();
            $data->expaire_time=Carbon\Carbon::now()->addDays(15);
            $data->name=$check_effect->name;
            $data->image=$check_effect->image;
            $data->effect=$check_effect->effect;
            $data->type=$check_effect->type;
            $data->save();
            $notification=array(
                'messege'=>'Effect Added Submited',
                'alert-type'=>'success'
            );
            return Redirect()->back()->with($notification);
            
        }else{
             $notification=array(
                'messege'=>'Effect Already Have',
                'alert-type'=>'success'
            );
            return Redirect()->back()->with($notification);
        }
    }
